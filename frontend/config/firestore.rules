rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Jobs — read-only for authenticated users, backend service account writes only
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Search alerts — per-user, only owner can read/write
    match /search_alerts/{alertId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // FCM tokens — per-user, only owner can read/write
    match /fcm_tokens/{tokenId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Notified jobs — per-user tracking (seen, hidden, notifiedAt)
    match /notified_jobs/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Saved keywords — per-user, only owner can read/write
    match /saved_keywords/{keywordId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
